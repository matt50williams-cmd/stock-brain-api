# OpenAI - Main analyst + web search
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Anthropic Claude - Deep reasoning analyst
# Get key at: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_key_here

# Google Gemini - Cross-checker / validator
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# xAI Grok - X/Twitter sentiment + social buzz
# Get key at: https://console.x.ai/
GROK_API_KEY=your_grok_key_here

# Finnhub - Real stock data, news, insider trading, congressional trading
# Get key at: https://finnhub.io/ (free signup)
FINNHUB_API_KEY=your_finnhub_key_here

# Server port (Render sets this automatically)
PORT=3000
